<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
  <id>dev.dergs.Tonearm</id>
  <metadata_license>MIT</metadata_license>
  <name>Tonearm</name>
  <summary>Stream your favorite music</summary>
  <description>
    <p>
    With Tonearm you are able to play tracks at their highest quality, explore new tracks using discovery mixes or the explore tab or just enjoy the songs you already know you love from your collection. Just like you would expect from the real app. Tonearm also has some additional features such as
    </p>
    <ul>
      <li>Background Playback</li>
      <li>Gapless playback</li>
      <li>MPRIS integration</li>
      <li>Scrobbling to ListenBrainz</li>
    </ul>
    <p>
    Don't have a TIDAL account? You can still try the app and enjoy song previews of up to 30 seconds to see if it's for you.
    </p>
  </description>
  <icon type="stock">dev.dergs.Tonearm</icon>

  <categories>
      <category>Audio</category>
      <category>AudioVideo</category>
      <category>Music</category>
  </categories>

  <keywords>
    <keyword translate="no">TIDAL</keyword>
    <keyword translate="no">MPRIS</keyword>
    <keyword translate="no">ListenBrainz</keyword>
    <keyword>music</keyword>
    <keyword>streaming</keyword>
  </keywords>

  <branding>
    <color type="primary" scheme_preference="light">#3a2aef</color>
    <color type="primary" scheme_preference="dark">#690daf</color>
  </branding>

  <url type="homepage">https://dergs.dev/projects/tonearm</url>
  <url type="bugtracker">https://codeberg.org/dergs/Tonearm/issues</url>
  <url type="vcs-browser">https://codeberg.org/dergs/Tonearm</url>

  <releases>
    <release version="0.0.1" date="2026-01-14">
      <url type="details">https://codeberg.org/dergs/Tonearm</url>
      <description>
        <p
                >Welcome to the first beta release of Tonearm. In this version, we added, well, everything. Give it a look and let us know what we can improve!</p>
          <ul>
            <li>Home, Explore and Collection pages</li>
            <li>View playlist, mixes, albums and artists</li>
            <li>Search functionality</li>
            <li>Play tracks, playlists, mixes and albums</li>
            <li>Sing along with the lyrics tab</li>
            <li>Control Tonearm using MPRIS</li>
            <li>Scrobble your listening activity with ListenBrainz</li>
          </ul>
      </description>
    </release>
  </releases>

  <launchable type="desktop-id">dev.dergs.Tonearm.desktop</launchable>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>


# Maintainer: RayZ3R0

pkgname=tonearm-bin
pkgver=1.5.1
pkgrel=1
pkgdesc="A Tidal music player for GNOME, built with GTK4 and Adwaita"
arch=('x86_64')
url="https://github.com/RayZ3R0/sonami-gtk"
license=('GPL-3.0-or-later')
provides=('tonearm')
conflicts=('tonearm' 'tonearm-git')

depends=(
    'gtk4'
    'libadwaita'
    'glib2'
    'gstreamer'
    'gst-plugins-base'
    'gst-plugins-good'
    'gst-plugins-bad'
    'libsecret'
    'hicolor-icon-theme'
)

optdepends=(
    'gst-plugins-ugly: additional media codec support'
    'gst-libav: additional media codec support via FFmpeg'
)

source=("${pkgname}-${pkgver}.tar.gz::https://github.com/RayZ3R0/sonami-gtk/releases/download/v${pkgver}/tonearm-v${pkgver}-linux-x86_64.tar.gz")
sha256sums=('SKIP')

package() {
    cd "${srcdir}/tonearm-v${pkgver}-linux-x86_64"

    # Binary
    install -Dm755 tonearm "${pkgdir}/usr/bin/tonearm"

    # Desktop entry
    install -Dm644 share/applications/dev.dergs.Tonearm.desktop \
        "${pkgdir}/usr/share/applications/dev.dergs.Tonearm.desktop"

    # AppStream metainfo
    install -Dm644 share/metainfo/dev.dergs.Tonearm.metainfo.xml \
        "${pkgdir}/usr/share/metainfo/dev.dergs.Tonearm.metainfo.xml"

    # Icons
    install -Dm644 share/icons/hicolor/scalable/apps/dev.dergs.Tonearm.svg \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/dev.dergs.Tonearm.svg"
    install -Dm644 share/icons/hicolor/128x128/apps/dev.dergs.Tonearm.png \
        "${pkgdir}/usr/share/icons/hicolor/128x128/apps/dev.dergs.Tonearm.png"
    install -Dm644 share/icons/hicolor/symbolic/apps/dev.dergs.Tonearm-symbolic.svg \
        "${pkgdir}/usr/share/icons/hicolor/symbolic/apps/dev.dergs.Tonearm-symbolic.svg"

    # GSettings schema
    install -Dm644 share/glib-2.0/schemas/dev.dergs.Tonearm.gschema.xml \
        "${pkgdir}/usr/share/glib-2.0/schemas/dev.dergs.Tonearm.gschema.xml"
}
